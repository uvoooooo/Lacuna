# Copy to .env and fill in. The pipeline runs offline (heuristic fallback)
# without these; set them to enable the LLM-backed agents via OpenRouter.

# Required to enable LLM mode. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Any OpenRouter model slug. Defaults to openai/gpt-4o-mini.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional. Defaults to https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=

# Optional. Used by OpenRouter for attribution (rankings page).
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
